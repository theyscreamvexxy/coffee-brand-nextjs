# .gitignore
# Purpose: Specifies files and directories to exclude from version control.

# Dependencies
node_modules/

# Next.js build output
.next/
out/

# Environment variables (never commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
*.tsbuildinfo
next-env.d.ts
